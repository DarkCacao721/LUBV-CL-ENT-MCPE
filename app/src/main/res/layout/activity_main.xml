<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/cyber_bg"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="◈ LUBV ◈"
        android:textSize="52sp"
        android:textColor="@color/cyber_cyan"
        android:textStyle="bold"
        android:typeface="monospace"
        android:shadowColor="@color/cyber_cyan"
        android:shadowRadius="20"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MOBILE CLIENT v1.0"
        android:textSize="14sp"
        android:textColor="@color/cyber_gray"
        android:typeface="monospace"
        android:layout_marginBottom="60dp" />

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hazır"
        android:textSize="16sp"
        android:textColor="@color/cyber_green"
        android:typeface="monospace"
        android:layout_marginBottom="60dp" />

    <Button
        android:id="@+id/btn_launch"
        android:layout_width="280dp"
        android:layout_height="60dp"
        android:text="▶ LUBV'Yİ ÇALIŞTIR"
        android:textSize="18sp"
        android:textColor="@color/cyber_white"
        android:textStyle="bold"
        android:typeface="monospace"
        android:backgroundTint="#FF1A1A2E"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_menu"
        android:layout_width="280dp"
        android:layout_height="60dp"
        android:text="☰ LUBV CLIENT MENÜ"
        android:textSize="18sp"
        android:textColor="@color/cyber_cyan"
        android:textStyle="bold"
        android:typeface="monospace"
        android:backgroundTint="#FF1A1A2E" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MCPE 1.21+ Desteği"
        android:textSize="11sp"
        android:textColor="@color/cyber_gray"
        android:typeface="monospace"
        android:layout_marginTop="40dp" />

</LinearLayout>
